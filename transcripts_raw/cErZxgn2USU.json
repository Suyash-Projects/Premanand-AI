 {"start": 135.2, "duration": 4.36, "text": "ही और"}, {"start": 139.84, "duration": 6.68, "text": "आ"}, {"start": 142.08, "duration": 4.44, "text": "ही और"}, {"start": 146.879, "duration": 3.761, "text": "हे"}, {"start": 148.8, "duration": 5.799, "text": "यह"}, {"start": 150.64, "duration": 3.959, "text": "है दे"}, {"start": 156.0, "duration": 4.72, "text": "नारी"}, {"start": 158.56, "duration": 5.16, "text": "नारी"}, {"start": 160.72, "duration": 3.0, "text": "नारी"}, {"start": 165.28, "duration": 5.12, "text": "और"}, {"start": 168.239, "duration": 5.161, "text": "नारी"}, {"start": 170.4, "duration": 3.0, "text": "दे"}, {"start": 174.239, "duration": 2.241, "text": "नारी"}, {"start": 176.56, "duration": 5.0, "text": "नाग"}, {"start": 178.56, "duration": 3.0, "text": "आ"}, {"start": 187.519, "duration": 3.0, "text": "दे"}, {"start": 191.2, "duration": 4.16, "text": "नारी"}, {"start": 193.519, "duration": 4.841, "text": "नारी"}, {"start": 195.36, "duration": 3.0, "text": "नारी"}, {"start": 199.44, "duration": 4.799, "text": "और"}, {"start": 202.08, "duration": 6.879, "text": "नारी"}, {"start": 204.239, "duration": 11.241, "text": "ते ना हो"}, {"start": 208.959, "duration": 6.521, "text": "और रा की और"}, {"start": 219.2, "duration": 4.8, "text": "ये"}, {"start": 221.519, "duration": 4.64, "text": "आ"}, {"start": 224.0, "duration": 3.942, "text": "ना"}, {"start": 226.159, "duration": 2.8, "text": "सुनी"}, {"start": 227.942, "duration": 4.017, "text": "[संगीत]"}, {"start": 228.959, "duration": 3.0, "text": "आ"}, {"start": 233.84, "duration": 4.88, "text": "ना"}, {"start": 235.84, "duration": 5.88, "text": "सुनी"}, {"start": 238.72, "duration": 3.0, "text": "आगे"}, {"start": 243.007, "duration": 2.02, "text": "[संगीत]"}, {"start": 248.64, "duration": 4.44, "text": "हूं ना"}, {"start": 253.68, "duration": 5.04, "text": "है [हंसी]"}, {"start": 256.239, "duration": 5.818, "text": "यह"}, {"start": 258.72, "duration": 3.337, "text": "का [संगीत]"}, {"start": 263.52, "duration": 3.0, "text": "होता"}, {"start": 266.72, "duration": 3.0, "text": "रूप"}, {"start": 269.759, "duration": 3.88, "text": "की और"}, {"start": 276.24, "duration": 7.0, "text": "ये है दासी"}, {"start": 280.24, "duration": 3.0, "text": "हरिदास"}, {"start": 283.52, "duration": 4.48, "text": "के स्वामी"}, {"start": 286.08, "duration": 3.679, "text": "श्यामा"}, {"start": 288.0, "duration": 3.52, "text": "को"}, {"start": 289.759, "duration": 4.761, "text": "ज"}, {"start": 291.52, "duration": 3.0, "text": "बिहारी"}, {"start": 294.639, "duration": 6.161, "text": "जी हरिदास"}, {"start": 298.32, "duration": 4.4, "text": "के स्वामी"}, {"start": 300.8, "duration": 4.92, "text": "श्याम"}, {"start": 302.72, "duration": 3.0, "text": "आ"}, {"start": 307.198, "duration": 2.02, "text": "[संगीत]"}, {"start": 310.08, "duration": 5.44, "text": "हरिदास"}, {"start": 313.039, "duration": 5.481, "text": "के स्वामी"}, {"start": 315.52, "duration": 3.0, "text": "श्यामा"}, {"start": 320.639, "duration": 3.0, "text": "बिहारी"}, {"start": 324.08, "duration": 3.0, "text": "या"}, {"start": 328.24, "duration": 4.08, "text": "मास"}, {"start": 330.08, "duration": 5.92, "text": "भाई [संगीत]"}, {"start": 332.32, "duration": 6.08, "text": "यह है भाई"}, {"start": 336.0, "duration": 6.039, "text": "और"}, {"start": 338.4, "duration": 3.639, "text": "की और"}, {"start": 344.32, "duration": 3.0, "text": "है"}, {"start": 348.463, "duration": 3.057, "text": "[हंसी]"}, {"start": 349.6, "duration": 3.12, "text": "महाराज जी स्वामी हरदास जी महाराज की"}, {"start": 351.52, "duration": 4.239, "text": "परंपरा मध्य"}, {"start": 352.72, "duration": 4.8, "text": "ध्रुपद परंपरा के मध्य श्री स्वामी जी की"}, {"start": 355.759, "duration": 2.961, "text": "श्री ललित मोहिनी देव जी महाराज द्वारा"}, {"start": 357.52, "duration": 1.519, "text": "बांधी गई बंदिश"}, {"start": 358.72, "duration": 3.039, "text": "जी"}, {"start": 359.039, "duration": 4.561, "text": "प्रकट कियो रस रीत गान को"}, {"start": 361.759, "duration": 3.921, "text": "संतन सेवा बन आई"}, {"start": 363.6, "duration": 3.039, "text": "तो ऐसे महाराज जी श्री स्वामी ललित मोहिनी"}, {"start": 365.68, "duration": 1.44, "text": "देव जी महाराज"}, {"start": 366.639, "duration": 3.201, "text": "जी"}, {"start": 367.12, "duration": 4.24, "text": "महान तो आपके गुरु जी है श्री स्वामी ललित"}, {"start": 369.84, "duration": 3.84, "text": "किशोरी देव जी महाराज"}, {"start": 371.36, "duration": 2.48, "text": "जिन्होंने टटिया स्थान की स्थापना करी"}, {"start": 373.68, "duration": 3.2, "text": "जी"}, {"start": 373.84, "duration": 6.16, "text": "तो आप परम रसिक सिरमौर जी"}, {"start": 376.88, "duration": 3.84, "text": "श्री स्वामी हरिदास जू को द्वितीय अनूप"}, {"start": 380.0, "duration": 3.52, "text": "रूप"}, {"start": 380.72, "duration": 5.199, "text": "श्री ललित किशोरी किधो ललित ललाम है"}, {"start": 383.52, "duration": 5.2, "text": "तो स्वामी हरदास जी महाराज ही द्वितीय वपू"}, {"start": 385.919, "duration": 4.881, "text": "से पधारे आप श्री ललित किशोरी देव जी"}, {"start": 388.72, "duration": 4.64, "text": "महाराज के स्वरूप में"}, {"start": 390.8, "duration": 3.839, "text": "तो आपके परम शिष्य श्री स्वामी ललित"}, {"start": 393.36, "duration": 3.6, "text": "मोहिनी देव जी महाराज"}, {"start": 394.639, "duration": 6.481, "text": "ऐसे परम रसिक अनन्य विराजे"}, {"start": 396.96, "duration": 6.799, "text": "जय जय एक बार श्री नामदेव जी एवं कबीर जी"}, {"start": 401.12, "duration": 3.76, "text": "श्री टटिया स्थान की परिक्रमा में पधारे"}, {"start": 403.759, "duration": 1.361, "text": "रात्रि काल में"}, {"start": 404.88, "duration": 2.8, "text": "जी"}, {"start": 405.12, "duration": 5.76, "text": "तब तब श्री स्वामी जी महाराज बोले कि अपने"}, {"start": 407.68, "duration": 5.2, "text": "शिष्य परकर से कि कोई श्री अरदास धीरे से"}, {"start": 410.88, "duration": 4.56, "text": "तो मोहिनीदास जी महाराज जग रहे थे"}, {"start": 412.88, "duration": 4.64, "text": "तो मोहिनी जी महाराज पधारे आपसे श्री"}, {"start": 415.44, "duration": 4.64, "text": "स्वामी ललित के सुदेव जी महाराज ने आज्ञा"}, {"start": 417.52, "duration": 3.519, "text": "करी कि देखो संत आए हुए हैं परिक्रमा में"}, {"start": 420.08, "duration": 2.959, "text": "दर्शन करो"}, {"start": 421.039, "duration": 4.641, "text": "तब श्री स्वामी ललित मोहिनी देव जी महाराज"}, {"start": 423.039, "duration": 4.16, "text": "ने इसी तटिया स्थान की परिक्रमा में"}, {"start": 425.68, "duration": 4.4, "text": "मोहिनी बिहारी जी के में"}, {"start": 427.199, "duration": 6.481, "text": "श्री कबीर जी और नामदेव जी के दर्शन कर"}, {"start": 430.08, "duration": 7.2, "text": "तो महाराज जी आप परम रसिक सम्राट और संगीत"}, {"start": 433.68, "duration": 6.16, "text": "के परम महान रसिक आचार्य तो आपने अपने"}, {"start": 437.28, "duration": 4.639, "text": "शिष्य श्री मोहिनीदास जी महाराज से आज्ञा"}, {"start": 439.84, "duration": 4.96, "text": "करी कि हमस कछु सीख लो"}, {"start": 441.919, "duration": 5.761, "text": "तो महाराज बोले कि महाराज जी सिखाओ तो"}, {"start": 444.8, "duration": 4.56, "text": "बोले हमसो राग सीख लो मोहिनीदास जी ने कही"}, {"start": 447.68, "duration": 5.359, "text": "राग सो क्या मिलेगो"}, {"start": 449.36, "duration": 4.64, "text": "तब गुरुदेव बोले कि राग सो अनुराग की"}, {"start": 453.039, "duration": 1.6, "text": "प्राप्ति होएगी"}, {"start": 454.0, "duration": 2.16, "text": "जी"}, {"start": 454.639, "duration": 2.96, "text": "प्रिया प्रीतम के लिए"}, {"start": 456.16, "duration": 3.759, "text": "महाराज जी मोहनिदास जी महाराज ने"}, {"start": 457.599, "duration": 5.04, "text": "प्रार्थना करी तो महाराज हमें अनुराग ही"}, {"start": 459.919, "duration": 3.84, "text": "प्रदान कर दो जब राग से अनुराग की"}, {"start": 462.639, "duration": 3.601, "text": "प्राप्ति होगी [हंसी]"}, {"start": 463.759, "duration": 5.28, "text": "तो आप कृपा करके हमें अनुराग ही प्रदान कर"}, {"start": 466.24, "duration": 3.679, "text": "दो। तब आचार्य चरण बोले जा तुमको अनुराग"}, {"start": 469.039, "duration": 4.081, "text": "दियो।"}, {"start": 469.919, "duration": 5.84, "text": "तब आपने वही अनुराग सो आज भी जो वर्तमान"}, {"start": 473.12, "duration": 4.96, "text": "समय में जो समाज परंपरा चल रही है वो श्री"}, {"start": 475.759, "duration": 4.961, "text": "स्वामी ललित मोहिनी देव जी महाराज की कृपा"}, {"start": 478.08, "duration": 6.16, "text": "और दास को बड़ा सौभाग्य मिल है और समाज"}, {"start": 480.72, "duration": 4.319, "text": "गायन की कृपा उनकी सेवा बड़े इनकी कृपा से"}, {"start": 484.24, "duration": 4.56, "text": "मिली है।"}, {"start": 485.039, "duration": 6.641, "text": "एक लोभ और जग गया जब आपने सुनाया एक पद और"}, {"start": 488.8, "duration": 6.385, "text": "सुना दो। भूख जैसे बढ़ जाती है ना अच्छा"}, {"start": 491.68, "duration": 3.84, "text": "भोजन मिले तो भूख बढ़ जाती।"}, {"start": 495.185, "duration": 2.255, "text": "[हंसी]"}, {"start": 495.52, "duration": 4.32, "text": "महाराज जी ठाकुर जी ने बड़ी कृपा करी है"}, {"start": 497.44, "duration": 3.12, "text": "महाराज जी ने कम से कम 20 वर्ष से यह समाज"}, {"start": 499.84, "duration": 4.4, "text": "की सेवा"}, {"start": 500.56, "duration": 4.16, "text": "हां बहुत सुंदर जीवन धन्य है महाराज जीवन"}, {"start": 504.24, "duration": 2.959, "text": "धन्य है"}, {"start": 504.72, "duration": 4.64, "text": "बालकाल से ठाकुर जी ने मोहिनी बिहारी जी"}, {"start": 507.199, "duration": 5.041, "text": "की सेवानी 19 वर्ष"}, {"start": 509.36, "duration": 4.32, "text": "ठाकुर जी की और वर्तमान जटेरी धाम एक बहुत"}, {"start": 512.24, "duration": 4.08, "text": "सुंदर स्थान बनो"}, {"start": 513.68, "duration": 5.599, "text": "महाराज जी ऐसे अद्भुत मोरों का नृत्य है"}, {"start": 516.32, "duration": 4.399, "text": "जो समाज गायन हो वीणा वादन और सामने मोर"}, {"start": 519.279, "duration": 3.2, "text": "बिहारी नाचे"}, {"start": 520.719, "duration": 4.081, "text": "के बिल्कुल एकदम निकट"}, {"start": 522.479, "duration": 5.841, "text": "आतं लड्डू पावे प्रसाद पावे"}, {"start": 524.8, "duration": 5.68, "text": "ऐसी अलौकिक छटा एक तरफ श्री गंधमादन पर्वत"}, {"start": 528.32, "duration": 4.639, "text": "एक तरफ श्री नर नारायण पर्वत"}, {"start": 530.48, "duration": 4.24, "text": "दोनों के मध्य तलहटली में विराजमान"}, {"start": 532.959, "duration": 3.521, "text": "श्री राधा प्रेम सरोवर"}, {"start": 534.72, "duration": 4.08, "text": "और वहां श्री जटेरी"}, {"start": 536.48, "duration": 6.0, "text": "जरूर कभी दर्शन करने आए"}, {"start": 538.8, "duration": 4.88, "text": "महाराज जी पद है एरी कहूं देखरी चंदन"}, {"start": 542.48, "duration": 3.84, "text": "चोलना"}, {"start": 543.68, "duration": 7.52, "text": "चंदन के ही रंग पे ठाकुर जी के भाव"}, {"start": 546.32, "duration": 9.84, "text": "गौरांगी के उवर राजत नील मनन को ढोलना"}, {"start": 551.2, "duration": 9.759, "text": "सकल श्रृंगार करो छावर नैन निरख मुख बोलना"}, {"start": 556.16, "duration": 6.48, "text": "श्री रसिक प्रिया पीतांबर दू राजत सहचरी ओ"}, {"start": 560.959, "duration": 4.681, "text": "श्री ललिता जी की गोद में"}, {"start": 562.64, "duration": 3.0, "text": "जी"}, {"start": 566.88, "duration": 5.12, "text": "का देख"}, {"start": 570.511, "duration": 3.649, "text": "[संगीत]"}, {"start": 572.0, "duration": 5.061, "text": "चंदन"}, {"start": 574.16, "duration": 4.0, "text": "शोना"}, {"start": 577.061, "duration": 5.059, "text": "[संगीत]"}, {"start": 578.16, "duration": 3.96, "text": "तेरी कहूं"}, {"start": 584.16, "duration": 4.76, "text": "चंदन"}, {"start": 585.92, "duration": 3.0, "text": "चोरी"}, {"start": 590.72, "duration": 2.116, "text": "का [संगीत]"}, {"start": 595.44, "duration": 3.519, "text": "चंदन"}, {"start": 597.279, "duration": 5.601, "text": "चोल"}, {"start": 598.959, "duration": 5.681, "text": "देखो री चंदन"}, {"start": 602.88, "duration": 4.16, "text": "चोलना"}, {"start": 604.64, "duration": 4.24, "text": "देखो री"}, {"start": 607.04, "duration": 4.84, "text": "चंदन"}, {"start": 608.88, "duration": 3.0, "text": "चोलना"}, {"start": 612.56, "duration": 7.36, "text": "ए का देख"}, {"start": 616.64, "duration": 7.08, "text": "री [संगीत] चंदन"}, {"start": 619.92, "duration": 3.8, "text": "जो गौरा"}, {"start": 624.64, "duration": 4.16, "text": "के"}, {"start": 627.04, "duration": 4.76, "text": "औरवर"}, {"start": 628.8, "duration": 3.0, "text": "राजत"}, {"start": 632.72, "duration": 3.0, "text": "गौरा"}, {"start": 636.32, "duration": 5.32, "text": "के"}, {"start": 638.64, "duration": 3.0, "text": "उरवर"}, {"start": 642.32, "duration": 4.227, "text": "जत"}, {"start": 644.399, "duration": 2.148, "text": "नीलमा [संगीत]"}, {"start": 647.12, "duration": 6.399, "text": "मेन को ढोलना"}, {"start": 650.72, "duration": 6.92, "text": "नीलमा"}, {"start": 653.519, "duration": 4.121, "text": "को ढोलना"}, {"start": 658.16, "duration": 5.2, "text": "तेरी कहूं"}, {"start": 661.519, "duration": 3.76, "text": "क्यों"}, {"start": 663.36, "duration": 7.4, "text": "चंदन"}, {"start": 665.279, "duration": 5.481, "text": "जो सकल [संगीत] श्रृंगार"}, {"start": 671.6, "duration": 3.0, "text": "रो"}, {"start": 676.622, "duration": 4.498, "text": "[संगीत]"}, {"start": 677.44, "duration": 5.36, "text": "सकल चंगार"}, {"start": 681.12, "duration": 4.68, "text": "का"}, {"start": 682.8, "duration": 3.0, "text": "रोवर"}, {"start": 688.32, "duration": 6.759, "text": "नैना ने"}, {"start": 691.12, "duration": 3.959, "text": "राख मोना"}, {"start": 702.24, "duration": 6.4, "text": "रा मुख वो रािक"}, {"start": 706.64, "duration": 5.0, "text": "प्रिया"}, {"start": 708.64, "duration": 3.0, "text": "की"}, {"start": 712.32, "duration": 3.0, "text": "दो"}, {"start": 716.0, "duration": 5.68, "text": "रसिक प्रिया"}, {"start": 719.44, "duration": 3.839, "text": "की"}, {"start": 721.68, "duration": 4.068, "text": "काम"}, {"start": 723.279, "duration": 3.68, "text": "दो"}, {"start": 725.748, "duration": 2.732, "text": "[संगीत]"}, {"start": 726.959, "duration": 3.521, "text": "रासिक"}, {"start": 728.48, "duration": 4.528, "text": "क्रिया"}, {"start": 730.48, "duration": 2.528, "text": "की [संगीत]"}, {"start": 734.16, "duration": 3.84, "text": "दो"}, {"start": 736.228, "duration": 5.452, "text": "[संगीत]"}, {"start": 738.0, "duration": 6.68, "text": "रसिक प्रिया"}, {"start": 741.68, "duration": 3.0, "text": "की"}, {"start": 745.279, "duration": 3.0, "text": "दो"}, {"start": 749.04, "duration": 4.56, "text": "राजत"}, {"start": 751.92, "duration": 3.359, "text": "सहच"}, {"start": 753.6, "duration": 3.6, "text": "बोलना"}, {"start": 755.279, "duration": 3.68, "text": "राजत"}, {"start": 757.2, "duration": 4.759, "text": "सहच"}, {"start": 758.959, "duration": 3.0, "text": "बोलना"}, {"start": 762.399, "duration": 3.88, "text": "तेरी का"}, {"start": 767.44, "duration": 3.36, "text": "चंदन"}, {"start": 769.2, "duration": 3.6, "text": "चोलना"}, {"start": 770.8, "duration": 3.68, "text": "देख"}, {"start": 772.8, "duration": 5.2, "text": "चंदन"}, {"start": 774.48, "duration": 5.359, "text": "चोलना देखो"}, {"start": 778.0, "duration": 4.839, "text": "चंदन"}, {"start": 779.839, "duration": 3.0, "text": "चोना"}, {"start": 782.88, "duration": 3.36, "text": "तेरी कहूं"}, {"start": 787.76, "duration": 4.079, "text": "चंदन"}, {"start": 789.44, "duration": 6.12, "text": "चो चंदन"}, {"start": 791.839, "duration": 3.721, "text": "चो चंद"}, {"start": 801.76, "duration": 8.72, "text": "महाराज जी ये दुर्लभ है प्रिया जी को अब"}, {"start": 805.44, "duration": 7.839, "text": "ये लुप्त प्राय लेकिन आपकी कृपा से अपनी"}, {"start": 810.48, "duration": 4.479, "text": "स्वामी जी ने कृपा करके बचा लिए तो ये"}, {"start": 813.279, "duration": 4.401, "text": "सरसों की वीणा है हमारे"}, {"start": 814.959, "duration": 6.481, "text": "तो तीन प्रकार की वीणा होती है।"}, {"start": 817.68, "duration": 6.56, "text": "एक रुद्र वीणा और तीसरी विचित्र वीणा आपके"}, {"start": 821.44, "duration": 7.04, "text": "आशीर्वाद तीनों वीणा"}, {"start": 824.24, "duration": 8.24, "text": "बज रही प्रात समय नवक कुंज द्वार भर"}, {"start": 828.48, "duration": 7.76, "text": "ललिताजु ललित बजाई वीणा पौड़े सुनत श्याम"}, {"start": 832.48, "duration": 7.44, "text": "श्री श्यामा दंपति चतुर प्रवीण प्रवीणा"}, {"start": 836.24, "duration": 7.599, "text": "अति अनुराग सुहाग परस्पर कुक कला निपुण"}, {"start": 839.92, "duration": 6.88, "text": "नवीन नवीना श्री बिहारी दास बल बल बंदस पर"}, {"start": 843.839, "duration": 5.921, "text": "मुदित प्राण न्यछावर की तो महाराज जी सुबह"}, {"start": 846.8, "duration": 5.599, "text": "सवेरे के समय प्रातः काल श्री ललिता जी"}, {"start": 849.76, "duration": 6.72, "text": "ठाकुर जी को जगा में मधुर मधुर स्वर से और"}, {"start": 852.399, "duration": 8.161, "text": "संध्या समय को ऐसा वर्णन आया हुआ है कि नव"}, {"start": 856.48, "duration": 7.12, "text": "निकुंज मंदिर में प्यारी पिया सिखावत बीना"}, {"start": 860.56, "duration": 7.36, "text": "प्रियाजू स्वयं ठाकुर जी को सिखावे तो तान"}, {"start": 863.6, "duration": 8.64, "text": "बंधान कल्याण मनोहर इत मन देहु प्रवीना"}, {"start": 867.92, "duration": 6.88, "text": "लेत संभार संवार सुगर नागरी कहत फवीना"}, {"start": 872.24, "duration": 4.24, "text": "श्री विट्ठल विपुल विनोद बिहारी को जानत"}, {"start": 874.8, "duration": 7.08, "text": "भेद कबीना"}, {"start": 876.48, "duration": 5.4, "text": "निकुंज मंदिर में प्यारी सिखावत"}, {"start": 889.199, "duration": 4.561, "text": "महाराज जी 22 को दर्शन एक संग वीणा में ही"}, {"start": 891.92, "duration": 4.64, "text": "हुआ"}, {"start": 893.76, "duration": 6.079, "text": "स्वर तो सात ही है पर श्रुति 22 है तो"}, {"start": 896.56, "duration": 6.695, "text": "इनको सूक्ष्म जो दर्शन है वो वीणा जी में"}, {"start": 899.839, "duration": 5.436, "text": "तार में"}, {"start": 903.255, "duration": 2.02, "text": "[संगीत]"}, {"start": 913.735, "duration": 2.02, "text": "[संगीत]"}, {"start": 927.49, "duration": 2.02, "text": "[संगीत]"}, {"start": 936.66, "duration": 2.02, "text": "[संगीत]"}, {"start": 947.14, "duration": 2.02, "text": "[संगीत]"}, {"start": 954.345, "duration": 2.02, "text": "[संगीत]"}, {"start": 956.56, "duration": 3.0, "text": "बाबा"}, {"start": 960.24, "duration": 2.021, "text": "[संगीत]"}, {"start": 964.826, "duration": 2.02, "text": "[संगीत]"}, {"start": 969.411, "duration": 2.02, "text": "[संगीत]"}, {"start": 973.996, "duration": 2.02, "text": "[संगीत]"}, {"start": 986.441, "duration": 2.02, "text": "[संगीत]"}, {"start": 1009.366, "duration": 2.02, "text": "[संगीत]"}, {"start": 1023.776, "duration": 2.02, "text": "[संगीत]"}, {"start": 1033.601, "duration": 2.02, "text": "[संगीत]"}, {"start": 1040.151, "duration": 2.02, "text": "[संगीत]"}, {"start": 1049.322, "duration": 2.02, "text": "[संगीत]"}, {"start": 1055.872, "duration": 2.02, "text": "[संगीत]"}, {"start": 1065.042, "duration": 2.02, "text": "[संगीत]"}, {"start": 1070.282, "duration": 2.02, "text": "[संगीत]"}, {"start": 1080.107, "duration": 2.02, "text": "[संगीत]"}, {"start": 1085.347, "duration": 4.133, "text": "[संगीत]"}, {"start": 1086.48, "duration": 3.0, "text": "आ"}, {"start": 1094.517, "duration": 3.123, "text": "[संगीत]"}, {"start": 1094.64, "duration": 3.0, "text": "आ"}, {"start": 1106.4, "duration": 3.0, "text": "आ"}, {"start": 1124.647, "duration": 2.02, "text": "[संगीत]"}, {"start": 1135.783, "duration": 2.02, "text": "[संगीत]"}, {"start": 1141.023, "duration": 2.02, "text": "[संगीत]"}, {"start": 1152.813, "duration": 2.02, "text": "[संगीत]"}, {"start": 1168.533, "duration": 2.02, "text": "[संगीत]"}, {"start": 1179.28, "duration": 3.0, "text": "रा"}, {"start": 1191.12, "duration": 3.0, "text": "आ"}, {"start": 1195.388, "duration": 2.02, "text": "[संगीत]"}, {"start": 1201.938, "duration": 2.02, "text": "[संगीत]"}, {"start": 1208.488, "duration": 2.02, "text": "[संगीत]"}, {"start": 1215.694, "duration": 2.02, "text": "[संगीत]"}, {"start": 1223.554, "duration": 2.02, "text": "[संगीत]"}, {"start": 1229.449, "duration": 2.02, "text": "[संगीत]"}, {"start": 1234.689, "duration": 2.02, "text": "[संगीत]"}, {"start": 1247.134, "duration": 2.02, "text": "[संगीत]"}, {"start": 1253.029, "duration": 2.02, "text": "[संगीत]"}, {"start": 1262.199, "duration": 2.02, "text": "[संगीत]"}, {"start": 1271.369, "duration": 2.02, "text": "[संगीत]"}, {"start": 1275.954, "duration": 2.02, "text": "[संगीत]"}, {"start": 1284.159, "duration": 4.801, "text": "जय हो"}, {"start": 1284.88, "duration": 7.679, "text": "श्री स्वामी जी महाराज की जय"}, {"start": 1288.96, "duration": 8.56, "text": "महाराज जी प्रातः कालीन संध्या प्रातः काल"}, {"start": 1292.559, "duration": 7.201, "text": "को बोलो संधि प्रकाश राग राग इंदौर जय"}, {"start": 1297.52, "duration": 4.159, "text": "महाराज जी आशीर्वाद दीजिए भक्ति बनी रहे।"}, {"start": 1299.76, "duration": 3.6, "text": "सबकी भक्ति लाखों के"}, {"start": 1301.679, "duration": 5.841, "text": "देखो"}, {"start": 1303.36, "duration": 8.0, "text": "संत समागम यदि मिल रहा है तो उससे लाखों"}, {"start": 1307.52, "duration": 6.639, "text": "गुना बढ़कर रसिक समागम और अगर रसिक समागम"}, {"start": 1311.36, "duration": 5.679, "text": "मिल रहा है तब हमें भक्ति की आकांक्षा"}, {"start": 1314.159, "duration": 6.241, "text": "नहीं करनी। सीधे भक्ति के फल की आकांक्षा"}, {"start": 1317.039, "duration": 6.721, "text": "करनी। जैसे महाराज जी ने बताया कि बताया"}, {"start": 1320.4, "duration": 6.8, "text": "कि राग नहीं अनुराग की आकांक्षा। तो भक्ति"}, {"start": 1323.76, "duration": 6.56, "text": "का फल प्रेम है तो रसिकों का संग मिला तो"}, {"start": 1327.2, "duration": 6.4, "text": "प्रेम दुर्लभ नहीं हां दुर्लभ है रसिकों"}, {"start": 1330.32, "duration": 8.44, "text": "का संग प्रेम दुर्लभ नहीं दुर्लभ रसिकों"}, {"start": 1333.6, "duration": 5.16, "text": "का संग है रसिकों संग मिला सब"}, {"start": 1339.2, "duration": 3.0, "text": "सिया"}]}