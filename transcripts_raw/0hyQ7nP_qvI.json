 "duration": 7.48, "text": "बोला से छबी"}, {"start": 649.68, "duration": 3.0, "text": "आई"}, {"start": 653.04, "duration": 8.2, "text": "हो के घनश्याम"}, {"start": 658.24, "duration": 3.0, "text": "खेल"}, {"start": 670.24, "duration": 3.0, "text": "हो"}, {"start": 675.36, "duration": 4.68, "text": "अभी"}, {"start": 677.04, "duration": 3.0, "text": "गुलाल"}, {"start": 680.64, "duration": 6.319, "text": "नै नलन में"}, {"start": 684.399, "duration": 5.56, "text": "अभी गुलाल"}, {"start": 686.959, "duration": 3.0, "text": "तेरी"}, {"start": 696.48, "duration": 4.52, "text": "अभी भर देन"}, {"start": 707.279, "duration": 4.0, "text": "में"}, {"start": 709.279, "duration": 6.201, "text": "नैना"}, {"start": 711.279, "duration": 4.201, "text": "में आत"}, {"start": 715.76, "duration": 8.12, "text": "मन आई छवि"}, {"start": 719.76, "duration": 4.12, "text": "प्यारी आज"}, {"start": 724.32, "duration": 3.72, "text": "मन आई"}, {"start": 728.079, "duration": 3.0, "text": "मोल"}, {"start": 738.56, "duration": 3.839, "text": "नैन"}, {"start": 740.72, "duration": 5.08, "text": "है"}, {"start": 742.399, "duration": 3.401, "text": "अभी रघुला"}, {"start": 754.959, "duration": 4.041, "text": "अभी हर"}, {"start": 759.04, "duration": 4.12, "text": "हर उलन"}, {"start": 765.839, "duration": 3.0, "text": "में"}, {"start": 771.44, "duration": 5.519, "text": "आज का रथ"}, {"start": 774.639, "duration": 6.76, "text": "मन भाई"}, {"start": 776.959, "duration": 4.44, "text": "छबी प्यारी"}, {"start": 782.56, "duration": 4.2, "text": "मन भाई"}, {"start": 789.92, "duration": 4.32, "text": "श्याम"}, {"start": 792.0, "duration": 3.92, "text": "बाजे"}, {"start": 794.24, "duration": 4.68, "text": "बजत"}, {"start": 795.92, "duration": 3.0, "text": "दो"}, {"start": 799.44, "duration": 4.959, "text": "के"}, {"start": 800.88, "duration": 7.8, "text": "मन माथे मो"}, {"start": 804.399, "duration": 4.281, "text": "बढ़ा आई"}, {"start": 808.959, "duration": 6.041, "text": "बाजे"}, {"start": 810.959, "duration": 4.041, "text": "वाला तेरी"}, {"start": 821.839, "duration": 3.961, "text": "बाजे हरि"}, {"start": 825.839, "duration": 3.0, "text": "बाजे"}, {"start": 834.16, "duration": 4.52, "text": "मन मत मोता"}, {"start": 844.24, "duration": 6.56, "text": "पिचकारी"}, {"start": 846.48, "duration": 6.88, "text": "रंग छत पिचकारी"}, {"start": 850.8, "duration": 4.08, "text": "मार मचाई"}, {"start": 853.36, "duration": 4.64, "text": "प्यारी"}, {"start": 854.88, "duration": 5.04, "text": "मार मचाई"}, {"start": 858.0, "duration": 6.079, "text": "के"}, {"start": 859.92, "duration": 9.359, "text": "छवि रंग छूटता पिचकारी"}, {"start": 864.079, "duration": 8.241, "text": "छवि रंग छूटता पिचकारी"}, {"start": 869.279, "duration": 4.881, "text": "मार मचाई"}, {"start": 872.32, "duration": 4.84, "text": "रघुवार"}, {"start": 874.16, "duration": 3.0, "text": "मचाई"}, {"start": 878.24, "duration": 11.92, "text": "गावत गीत रस रीत जीत के"}, {"start": 883.92, "duration": 6.24, "text": "सुखदा पाई गावत गीत तेरी"}, {"start": 892.72, "duration": 5.2, "text": "गावत"}, {"start": 894.72, "duration": 5.28, "text": "गावत गीत रस"}, {"start": 897.92, "duration": 4.479, "text": "जय"}, {"start": 900.0, "duration": 9.6, "text": "सुखदाई"}, {"start": 902.399, "duration": 8.961, "text": "रस बिहारी लगी छवि रस बिहार लगी छवि"}, {"start": 909.6, "duration": 9.599, "text": "जोधा"}, {"start": 911.36, "duration": 12.2, "text": "छाई छवि जो घन छाई होली खेलन श्याम खेलन"}, {"start": 919.199, "duration": 4.361, "text": "श्याम बोला सली"}, {"start": 923.68, "duration": 3.0, "text": "खे"}, {"start": 932.32, "duration": 7.36, "text": "बहुत बहुत कृपा बहुत कृपा ये अमृत रस आप"}, {"start": 937.04, "duration": 6.799, "text": "ही रसिक महापुरुषों के द्वारा मिल सकता"}, {"start": 939.68, "duration": 6.399, "text": "है। दुर्लभ रस प्रभुंद पाद जी ने तीन"}, {"start": 943.839, "duration": 6.881, "text": "वृंदावन का वर्णन किया। जी"}, {"start": 946.079, "duration": 6.88, "text": "एक वर्णन किया गोष्ठ वृंदावन"}, {"start": 950.72, "duration": 2.96, "text": "एक वर्णन किया गोपी वृंदावन"}, {"start": 952.959, "duration": 4.081, "text": "जी"}, {"start": 953.68, "duration": 4.159, "text": "एक राधा निकुंज वाटी वृंदावन करके संकेत"}, {"start": 957.04, "duration": 5.12, "text": "किया है"}, {"start": 957.839, "duration": 7.201, "text": "जो राधा निकुंज वाटी वृंदावन है ये य"}, {"start": 962.16, "duration": 6.0, "text": "नारदा सुख अगम्यम"}, {"start": 965.04, "duration": 7.599, "text": "वृंदावन वंजुल मंज कुंजे"}, {"start": 968.16, "duration": 5.919, "text": "त कृष्ण चेतो हरण विज्ञ मत्रास्त किंचित"}, {"start": 972.639, "duration": 5.921, "text": "परम रहस्यम"}, {"start": 974.079, "duration": 8.32, "text": "जो नारद जी श्री सुखदेव जी इस भगवान शंकर"}, {"start": 978.56, "duration": 4.24, "text": "और ब्रह्मा की भी दृष्टि से अगोचर वृंदावन"}, {"start": 982.399, "duration": 0.961, "text": "है।"}, {"start": 982.8, "duration": 4.56, "text": "जी"}, {"start": 983.36, "duration": 7.12, "text": "इनके द्वारा अगोचर है। जहां श्री लाडली जू"}, {"start": 987.36, "duration": 6.96, "text": "अपनी दृष्टि से चित्त का आकर्षण करके"}, {"start": 990.48, "duration": 8.0, "text": "लालजु को अधीन किए हुए भैकुट निर्जित मदन"}, {"start": 994.32, "duration": 7.28, "text": "मंद सस्मित बदन किए रस विवस घनश्याम पिय"}, {"start": 998.48, "duration": 5.919, "text": "गोरी इस वृंदावन में किसी का प्रवेश नहीं"}, {"start": 1001.6, "duration": 6.4, "text": "ये स्वामी जी महाराज हरिराम व्यास जी"}, {"start": 1004.399, "duration": 6.481, "text": "महाराज जी रस त्रिवेणी यही कृपा"}, {"start": 1008.0, "duration": 4.079, "text": "जी आचार्य चरणन ने जो कृपा करी है वो वितन"}, {"start": 1010.88, "duration": 1.6, "text": "वृंदाव पे"}, {"start": 1012.079, "duration": 2.961, "text": "जी"}, {"start": 1012.48, "duration": 6.0, "text": "ये हमारा रसकंद"}, {"start": 1015.04, "duration": 6.479, "text": "तो हमारा वृंदावन तो यही है तन बन के बन"}, {"start": 1018.48, "duration": 7.199, "text": "तन भयो कछु बरो बरनो न जाए"}, {"start": 1021.519, "duration": 8.081, "text": "कदली कुंद कदंब अंब बन बीथन बर विमाए तन"}, {"start": 1025.679, "duration": 6.4, "text": "मन के धो बन तन भयो कछु बरो बरनो न जाए"}, {"start": 1029.6, "duration": 5.76, "text": "तो महाराज जी वही श्री प्रियाजू को श्री"}, {"start": 1032.079, "duration": 4.161, "text": "अंग रूपी वृंदावन वा वृंदारण्यम स्वपद"}, {"start": 1035.36, "duration": 2.719, "text": "रमणम"}, {"start": 1036.24, "duration": 3.76, "text": "रमणम रति प्रदम"}, {"start": 1038.079, "duration": 4.48, "text": "क्योंकि नहीं तो और भी शब्द आ सकते लेकिन"}, {"start": 1040.0, "duration": 5.6, "text": "रमणम शब्द है रति प्रदम"}, {"start": 1042.559, "duration": 4.24, "text": "तो गुप्त रूप से आचार्यन को इशारो निकुंजन"}, {"start": 1045.6, "duration": 4.199, "text": "को ही"}, {"start": 1046.799, "duration": 3.0, "text": "वही"}, {"start": 1050.559, "duration": 8.721, "text": "ये वस्तु आपकी ये आपके ही योग्य और तो फिर"}, {"start": 1056.24, "duration": 5.439, "text": "आचार्यों ने अपने लोगों को परोसा"}, {"start": 1059.28, "duration": 6.24, "text": "उस त्रिभुवन में कहीं नहीं है"}, {"start": 1061.679, "duration": 6.481, "text": "तो ये प्यास केवल यही बुझ पाई"}, {"start": 1065.52, "duration": 3.76, "text": "और कहीं ना आगमों में है ना निगमों में है"}, {"start": 1068.16, "duration": 6.16, "text": "ना पुराणों में है"}, {"start": 1069.28, "duration": 5.04, "text": "जे रस बिसरी छदा पिपासा रस"}, {"start": 1074.559, "duration": 6.48, "text": "जय महाराज आपको रोम रोम पुल जाता है आपके"}, {"start": 1078.88, "duration": 6.44, "text": "आरती यही"}, {"start": 1081.039, "duration": 4.281, "text": "जय जय माता"}, {"start": 1086.24, "duration": 2.96, "text": "सियाराम"}]}