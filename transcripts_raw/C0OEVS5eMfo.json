{"video_id": "C0OEVS5eMfo", "title": "Abhilipsa Panda द्वारा \"वेदसार शिव स्तोत्रम\" का मधुर गायन with Lyrics | Bhajan Marg", "playlist": "Bhajan Marg - Videos", "language": "hi-auto", "segments": 77, "transcript": [{"start": 0.24, "duration": 4.28, "text": "वेद सार शिवस्तव"}, {"start": 4.56, "duration": 9.199, "text": "पशु नाम पति पापनाश"}, {"start": 8.48, "duration": 7.92, "text": "परश गजेंद्रस कृत वसानं"}, {"start": 13.759, "duration": 5.641, "text": "वरेण्य जटाज"}, {"start": 16.4, "duration": 3.0, "text": "मध्यगाव"}, {"start": 19.92, "duration": 6.68, "text": "महादेव मेकम स्मराम स्मरारी"}, {"start": 27.279, "duration": 5.28, "text": "महेश सुरेश"}, {"start": 29.76, "duration": 5.28, "text": "सुरनाशम"}, {"start": 32.559, "duration": 4.081, "text": "विभ विश्वनाथ"}, {"start": 35.04, "duration": 4.71, "text": "विभंग"}, {"start": 36.64, "duration": 4.8, "text": "भूषम विूपाक्षम"}, {"start": 39.75, "duration": 5.53, "text": "[संगीत]"}, {"start": 41.44, "duration": 6.09, "text": "त्रनेत्रम सदानंद"}, {"start": 45.28, "duration": 5.2, "text": "प्रभु पंचवक्रम"}, {"start": 47.53, "duration": 6.31, "text": "[संगीत]"}, {"start": 50.48, "duration": 8.12, "text": "गिरीश गणेशंगले"}, {"start": 53.84, "duration": 4.76, "text": "नील वर्णम गवेंद्र्राधूंगणा"}, {"start": 58.64, "duration": 12.0, "text": "ती रूपम भव भास भस्मना भूषितांगम"}, {"start": 65.76, "duration": 7.359, "text": "भवानी कलत्र भजे पंचवत्रम"}, {"start": 70.64, "duration": 4.08, "text": "[संगीत]"}, {"start": 73.119, "duration": 4.161, "text": "शिवाकांत"}, {"start": 74.72, "duration": 5.28, "text": "शंभू शशकाध"}, {"start": 77.28, "duration": 5.199, "text": "मले महेश"}, {"start": 80.0, "duration": 8.88, "text": "श जटा"}, {"start": 82.479, "duration": 13.64, "text": "धारी तमे को जगत व्यापको विश्वू रूप"}, {"start": 88.88, "duration": 7.239, "text": "प्रसिद्ध प्रसिद्ध प्रभु पूर्ण रूप"}, {"start": 96.479, "duration": 4.0, "text": "परात्मक"}, {"start": 98.88, "duration": 6.64, "text": "जगतज"}, {"start": 100.479, "duration": 10.081, "text": "माध्यम निरीहं निराकारमकार"}, {"start": 105.52, "duration": 9.279, "text": "वेद यतो जाते पालते"}, {"start": 110.56, "duration": 8.04, "text": "विश्वं तमी भजेते"}, {"start": 114.799, "duration": 3.801, "text": "यत्र विश्वंम"}, {"start": 118.88, "duration": 14.48, "text": "न भूमि न चापो न वन न वायुर न चाकास"}, {"start": 126.719, "duration": 11.52, "text": "न तंद्रा न निद्रा न गश्मो न शतो न देशो न"}, {"start": 133.36, "duration": 7.879, "text": "वेशो न यस्यास्त मूर्ति स्त्री मूर्ति"}, {"start": 138.239, "duration": 3.0, "text": "तमीडे"}, {"start": 141.84, "duration": 4.24, "text": "अजं शाश्वतम"}, {"start": 144.16, "duration": 9.84, "text": "कारण"}, {"start": 146.08, "duration": 10.92, "text": "नाम शिवम केवलं भाषकं भाषका नाम तुरंत तम"}, {"start": 154.0, "duration": 3.0, "text": "पारमांतहीनम"}, {"start": 157.12, "duration": 6.04, "text": "प्रपद्य परम पावन द्वैतहीनम"}, {"start": 164.64, "duration": 9.12, "text": "नमस्ते नमस्ते विभ विश्व मूर्त नमस्ते"}, {"start": 170.879, "duration": 10.0, "text": "नमस्ते चिदंतम"}, {"start": 173.76, "duration": 13.08, "text": "मूर्त नमस्ते नमस्ते तपो योग गम्य नमस्ते"}, {"start": 180.879, "duration": 5.961, "text": "नमस्ते श्रुति ज्ञान गम्य"}, {"start": 187.12, "duration": 11.759, "text": "प्रभु शूल पाण विभो विश्वनाथ"}, {"start": 192.319, "duration": 11.441, "text": "महादेव शंभू महेश त्रिनेत्र शिवाकांत"}, {"start": 198.879, "duration": 10.201, "text": "शांत स्मरार पुरार तदन"}, {"start": 203.76, "duration": 5.32, "text": "वर न मान्यो नगन्य"}, {"start": 209.519, "duration": 7.8, "text": "शंभू महेश करुणामय"}, {"start": 213.519, "duration": 3.8, "text": "शूल पाणी"}, {"start": 217.44, "duration": 4.719, "text": "गौरी पति"}, {"start": 220.319, "duration": 4.441, "text": "पशुपते"}, {"start": 222.159, "duration": 4.261, "text": "पशुपानाशी"}, {"start": 224.76, "duration": 3.399, "text": "[प्रशंसा]"}, {"start": 226.42, "duration": 6.78, "text": "[संगीत]"}, {"start": 228.159, "duration": 7.041, "text": "काशी पते करुणाया"}, {"start": 233.2, "duration": 4.88, "text": "जग"}, {"start": 235.2, "duration": 7.44, "text": "देम"}, {"start": 238.08, "duration": 7.56, "text": "हंस पास विधासी"}, {"start": 242.64, "duration": 3.0, "text": "महेश्वरोसी"}, {"start": 248.0, "duration": 9.12, "text": "ततो जगत भवती"}, {"start": 252.56, "duration": 7.56, "text": "देव भव स्मर"}, {"start": 257.12, "duration": 3.0, "text": "तष्टते"}, {"start": 260.479, "duration": 5.16, "text": "जगन"}, {"start": 262.639, "duration": 3.0, "text": "विश्वनाथ"}, {"start": 267.04, "duration": 4.879, "text": "तव"}, {"start": 268.56, "duration": 5.359, "text": "गच्छती लय"}, {"start": 271.919, "duration": 4.641, "text": "जगदी"}, {"start": 273.919, "duration": 4.801, "text": "देश"}, {"start": 276.56, "duration": 6.079, "text": "लिंगात्मक"}, {"start": 278.72, "duration": 6.919, "text": "चर हरा हर"}, {"start": 282.639, "duration": 3.0, "text": "स्वरूप"}, {"start": 286.0, "duration": 9.04, "text": "इ श्रीमद शंकराचार्य कृत श्री वेद सार शिव"}, {"start": 292.08, "duration": 6.16, "text": "संपूर्णम"}, {"start": 295.04, "duration": 6.2, "text": "बहुत सुंदर बहुत सुंदर सुनाया भाव से"}, {"start": 298.24, "duration": 3.0, "text": "सुनाया"}]}