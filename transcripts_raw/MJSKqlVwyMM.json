": 402.96, "duration": 6.48, "text": "सावधानी है कि कोई वैष्णव अपराध ना बने"}, {"start": 406.0, "duration": 6.88, "text": "कोई वैष्णव अपराध ना बने कोई संत द्रोह ना"}, {"start": 409.44, "duration": 7.039, "text": "बने और व्यभिचार प्रवृत्ति में ना फंसे"}, {"start": 412.88, "duration": 5.84, "text": "क्योंकि सर्वत्र जाना है सबसे मिलना है हर"}, {"start": 416.479, "duration": 5.521, "text": "प्रकार के व्यक्ति से मिलना है तो अपनी"}, {"start": 418.72, "duration": 6.24, "text": "सेफ्टी के लिए अपनी परमार्थ सेफ्टी के लिए"}, {"start": 422.0, "duration": 6.479, "text": "वैष्णव अपराध ना बने संत द्रोह ना होने"}, {"start": 424.96, "duration": 6.799, "text": "पावे और व्यभचार प्रवृत्ति ना होने पावे"}, {"start": 428.479, "duration": 6.16, "text": "हमारे अंदर पर स्त्री गमन की भावना ना"}, {"start": 431.759, "duration": 5.761, "text": "बनने पावे तो यही नाम कीर्तन जगत मंगल"}, {"start": 434.639, "duration": 6.081, "text": "करने वाला है नाम संकीर्तनम सर्व पाप"}, {"start": 437.52, "duration": 5.679, "text": "प्रणाशनम सबके पापों का नाश कर देगा। आप"}, {"start": 440.72, "duration": 5.28, "text": "नाम कीर्तन कर रहे हैं और जितने सुन रहे"}, {"start": 443.199, "duration": 7.201, "text": "हैं सब निष्पाप हो जाएंगे। कलयुग में केवल"}, {"start": 446.0, "duration": 7.52, "text": "हरि नाम हरे नाम हरे नाम केवलम कल नास्ते"}, {"start": 450.4, "duration": 5.68, "text": "नास्त नास्ते गति अन्य था। अन्य युगों में"}, {"start": 453.52, "duration": 5.44, "text": "और भी साधन थे। कलयुग में केवल भगवन नाम"}, {"start": 456.08, "duration": 6.8, "text": "साधन है। बस नाम अपराध में जो पहला अपराध"}, {"start": 458.96, "duration": 6.88, "text": "है संत द्रोह संत निंदा। अगर हम संत निंदा"}, {"start": 462.88, "duration": 6.64, "text": "संत द्रोह से वैष्णव अपराध से बच जाए और"}, {"start": 465.84, "duration": 6.16, "text": "व्यभचार दोष ना आने पावे पर स्त्री गमन वो"}, {"start": 469.52, "duration": 4.959, "text": "ना आने पावे समझ रहे हैं ना आप तो हम"}, {"start": 472.0, "duration": 5.12, "text": "बिल्कुल कवच युक्त होकर जाएंगे हमें कोई"}, {"start": 474.479, "duration": 5.28, "text": "गिरा नहीं सकता कलयुग की कुचाल हमें गिरा"}, {"start": 477.12, "duration": 5.44, "text": "नहीं पाएगी और हम देश विदेश सर्वत्र भगवन"}, {"start": 479.759, "duration": 5.921, "text": "नाम का प्रचार करें हम आपको धन्यवाद देते"}, {"start": 482.56, "duration": 6.0, "text": "हैं कि आप देश विदेशों में भगवन नाम जाकर"}, {"start": 485.68, "duration": 5.44, "text": "हम तो यही बैठे जो बोलते हैं आप तो जाकर"}, {"start": 488.56, "duration": 5.28, "text": "के नाम सुना रहे हैं गा करके उनको उनको"}, {"start": 491.12, "duration": 5.199, "text": "गाने का अभ्यास उनको आनंद दे रहे हैं। जो"}, {"start": 493.84, "duration": 5.12, "text": "भोगों में रथ है जानते ही नहीं कि नाम का"}, {"start": 496.319, "duration": 5.681, "text": "आनंद क्या है। वो जानते ही नहीं नाम का"}, {"start": 498.96, "duration": 5.519, "text": "आनंद क्या है। जो केवल रस्द और जनेंद्र के"}, {"start": 502.0, "duration": 5.759, "text": "भोगों में रथ है उनको भगवन नाम सुनाते"}, {"start": 504.479, "duration": 6.801, "text": "हैं। धन्यवाद है। आप ऐसे स्वस्थ रह के और"}, {"start": 507.759, "duration": 6.081, "text": "प्रसन्न मुद्रा में भगवन नाम गायन कीजिए।"}, {"start": 511.28, "duration": 2.56, "text": "हम्म।"}]}