ration": 6.04, "text": "पा सुरे"}, {"start": 324.32, "duration": 3.0, "text": "सम"}, {"start": 328.479, "duration": 5.72, "text": "सस्या"}, {"start": 331.199, "duration": 3.0, "text": "समो"}, {"start": 337.84, "duration": 3.72, "text": "असिया पा"}, {"start": 343.919, "duration": 5.28, "text": "स्वाहा"}, {"start": 346.32, "duration": 4.4, "text": "स्वाहा"}, {"start": 349.199, "duration": 4.521, "text": "सुर्या"}, {"start": 350.72, "duration": 3.0, "text": "समू"}, {"start": 354.16, "duration": 3.0, "text": "समस्या"}, {"start": 357.44, "duration": 5.319, "text": "सम"}, {"start": 359.759, "duration": 3.0, "text": "सम"}, {"start": 364.08, "duration": 3.72, "text": "अस पा"}, {"start": 370.16, "duration": 5.479, "text": "स्वाहा"}, {"start": 372.639, "duration": 3.0, "text": "स्वाहा"}, {"start": 377.84, "duration": 2.88, "text": "जय हो बहुत दुर्लभ वस्तु बहुत दुर्लभ"}, {"start": 380.24, "duration": 2.64, "text": "वस्तु"}, {"start": 380.72, "duration": 5.44, "text": "ये महाराज जी 200 साल पूर्व एक पारण हुआ"}, {"start": 382.88, "duration": 6.24, "text": "था किसी विद्वान ने किया था उनका नाम"}, {"start": 386.16, "duration": 4.8, "text": "नारायण शास्त्री जी था नासिक के"}, {"start": 389.12, "duration": 5.199, "text": "उसके बाद किसी ने पारण नहीं किया महाराज"}, {"start": 390.96, "duration": 5.92, "text": "जी 2000 मंत्र उसमें है ये तो छोटा मंत्र"}, {"start": 394.319, "duration": 5.121, "text": "लेकिन ऐसा मंत्र मंत्र का विस्तार होता है"}, {"start": 396.88, "duration": 4.72, "text": "तब एक-ए मंत्र कम से कम डेढ़ दोद घंटा"}, {"start": 399.44, "duration": 5.039, "text": "चलता है एक एक ही मंत्र"}, {"start": 401.6, "duration": 5.599, "text": "तो एक पद आगे आना है एक पीछे आना है फिर"}, {"start": 404.479, "duration": 5.28, "text": "से वो पीछे लेकर अगला पद लेकर जितना आगे"}, {"start": 407.199, "duration": 5.041, "text": "गए उतना पीछे उल्टा बोलना है"}, {"start": 409.759, "duration": 6.081, "text": "माने मंत्र उल्टा बोलना है कृष्णाय"}, {"start": 412.24, "duration": 8.799, "text": "वासुदेवाय वासुदेवाय कृष्णाय कृष्णााय"}, {"start": 415.84, "duration": 8.799, "text": "वासुदेवाय वासुदेवाय हर हर वासुदेवाय"}, {"start": 421.039, "duration": 7.041, "text": "कृष्णा [हंसी] कृष्णा वासुदेवाय वासुदेवाय"}, {"start": 424.639, "duration": 4.481, "text": "हर हर परमात्मने अभी परमात्मने से लेकर"}, {"start": 428.08, "duration": 4.399, "text": "उल्टा मंत्र बोलना है"}, {"start": 429.12, "duration": 7.04, "text": "परमात्माने हर जय वासुदेवाय कृष्णा"}, {"start": 432.479, "duration": 7.12, "text": "ऐसा उसकी पद्धति है उसका"}, {"start": 436.16, "duration": 6.479, "text": "ये इसलिए है कि वेदों का रक्षण हो वेद के"}, {"start": 439.599, "duration": 4.32, "text": "मंत्र जो है उसमें किसी प्रकार का पाठ भेद"}, {"start": 442.639, "duration": 3.84, "text": "नहीं आए"}, {"start": 443.919, "duration": 5.28, "text": "कभी हम कोई चौपाई देखते हैं उसमें पाठ भेद"}, {"start": 446.479, "duration": 5.28, "text": "होता है या कोई ग्रंथ देखते हैं मनुष्य"}, {"start": 449.199, "duration": 4.801, "text": "ग्रंथ में तो उसमें पाठ भेद अपने को दिखाई"}, {"start": 451.759, "duration": 4.641, "text": "देता है। किसी प्रकाशन में यह पाठ भेद है"}, {"start": 454.0, "duration": 4.24, "text": "उसमें पाठ भेद है। लेकिन वेद मंत्र की यह"}, {"start": 456.4, "duration": 4.48, "text": "महत्ता है कि वेद मंत्र में किसी भी"}, {"start": 458.24, "duration": 5.2, "text": "प्रकार का पाठ भेद अक्षर भेद भी नहीं है।"}, {"start": 460.88, "duration": 4.0, "text": "ना किसी मात्रा का भी फर्क नहीं है और"}, {"start": 463.44, "duration": 2.64, "text": "स्वर का भी फर्क नहीं है।"}, {"start": 464.88, "duration": 3.84, "text": "जी"}, {"start": 466.08, "duration": 3.44, "text": "जय हो जय हो। बहुत सुंदर बहुत सुंदर"}, {"start": 468.72, "duration": 3.36, "text": "आनंद महाराज"}, {"start": 469.52, "duration": 4.959, "text": "बहुत सुंदर"}, {"start": 472.08, "duration": 5.76, "text": "महाराज जी काशी विश्वनाथ का प्रसाद और"}, {"start": 474.479, "duration": 6.081, "text": "भगवान बिंदु माधव काशी में है और ये पारण"}, {"start": 477.84, "duration": 7.12, "text": "काशी में हुआ था 50 दिन बिंदु माधव का"}, {"start": 480.56, "duration": 7.12, "text": "महाराज जी विश्वेश्वम माधवम दंडम दंड भैरव"}, {"start": 484.96, "duration": 5.04, "text": "वंदे काशी गंगा भवानी मणिका"}, {"start": 487.68, "duration": 4.16, "text": "गुरुदेव दत्त"}, {"start": 490.0, "duration": 6.319, "text": "दंडवत दंडवत"}, {"start": 491.84, "duration": 5.6, "text": "नमो नमो ब्रह्मण देवाय ब्राह्मण"}, {"start": 496.319, "duration": 3.201, "text": "कृष्ण"}, {"start": 497.44, "duration": 4.0, "text": "अभी और आगे पढ़ने वाला बालक अभी 19 साल"}, {"start": 499.52, "duration": 5.28, "text": "उसकी उम्र है और आगे"}, {"start": 501.44, "duration": 8.8, "text": "नहीं बहुत सुंदर बहुत सुंदर संभालिएगा"}, {"start": 504.8, "duration": 5.44, "text": "हां आगे बढ़ाइएगा बहुत सुंदर बहुत सुंदर"}]}