}, {"start": 838.8, "duration": 3.52, "text": "ऐसी"}, {"start": 840.399, "duration": 10.401, "text": "हो"}, {"start": 842.32, "duration": 12.44, "text": "जो सो ज मिले तन सो तन समा"}, {"start": 850.8, "duration": 3.96, "text": "देखो कहा"}, {"start": 861.199, "duration": 5.601, "text": "पर्दा को जो आनंद है वो पर्दा तो यहां है"}, {"start": 863.839, "duration": 7.761, "text": "ही ना"}, {"start": 866.8, "duration": 6.56, "text": "दे दरस बाके"}, {"start": 871.6, "duration": 4.479, "text": "बिहारी"}, {"start": 873.36, "duration": 4.64, "text": "क्यों रहे"}, {"start": 876.079, "duration": 3.681, "text": "पर्दे"}, {"start": 878.0, "duration": 4.079, "text": "में है"}, {"start": 879.76, "duration": 4.079, "text": "बेदरस"}, {"start": 882.079, "duration": 3.361, "text": "बांके"}, {"start": 883.839, "duration": 5.68, "text": "बिहारी"}, {"start": 885.44, "duration": 5.92, "text": "क्यों रहे पर्दे"}, {"start": 889.519, "duration": 5.44, "text": "में है"}, {"start": 891.36, "duration": 5.44, "text": "आप तो पर्दे"}, {"start": 894.959, "duration": 5.68, "text": "में बैठे"}, {"start": 896.8, "duration": 5.68, "text": "हम यूं ही तनहा"}, {"start": 900.639, "duration": 5.2, "text": "रहे"}, {"start": 902.48, "duration": 5.2, "text": "आप तो पर्दे"}, {"start": 905.839, "duration": 5.36, "text": "में बैठे"}, {"start": 907.68, "duration": 5.04, "text": "हम यूं ही तनहा"}, {"start": 911.199, "duration": 10.0, "text": "रहे"}, {"start": 912.72, "duration": 13.76, "text": "हमको पर्दे में छिपा लो हमको पर्दे में"}, {"start": 921.199, "duration": 13.121, "text": "छिपा लो तो आनंद पर्दे"}, {"start": 926.48, "duration": 11.44, "text": "में हमको को पर्दे में बुला लो तो आनंद"}, {"start": 934.32, "duration": 6.079, "text": "पर्दे में है"}, {"start": 937.92, "duration": 7.84, "text": "द रस बांके"}, {"start": 940.399, "duration": 8.361, "text": "बिहारी क्यों रहे"}, {"start": 945.76, "duration": 3.0, "text": "हो"}, {"start": 950.24, "duration": 3.399, "text": "चला जाए"}, {"start": 955.759, "duration": 3.561, "text": "याद करोगे जब"}, {"start": 960.72, "duration": 7.4, "text": "आई ही आपसे मिलने के लिए तो जाने का"}, {"start": 963.839, "duration": 4.281, "text": "रास्ता ही नहीं है। आपके"}, {"start": 970.88, "duration": 9.92, "text": "सभी देखत ही मैं तो छाक रही मेरो चित्त"}, {"start": 976.8, "duration": 10.24, "text": "चुराई लियो छाखन में"}, {"start": 980.8, "duration": 10.159, "text": "ये राम बसो जिए राम बसो प्यारो प्यारो बसो"}, {"start": 987.04, "duration": 7.359, "text": "दो आखन में कहां जाएंगे तो आपके हृदय में"}, {"start": 990.959, "duration": 3.44, "text": "विराजमान है"}]}