# =============================================================================
# Bhakti Marg AI - Production Environment Configuration
# =============================================================================

# Application
APP_NAME=Bhakti Marg AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/bhaktimarg
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Security
API_KEY_HEADER=X-API-Key
ALLOWED_ORIGINS=["http://localhost:3000","https://your-domain.com"]
API_KEY_1=your-secure-api-key-1
API_KEY_2=your-secure-api-key-2

# LLM Providers (at least one required)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
APIFREE_API_KEY=
APIFREE_BASE_URL=https://apifreellm.com/api/v1

# RAG Settings
RAG_THRESHOLD=0.40
RAG_TOP_K=8

# Force UTF-8 output on Windows
PYTHONUTF8=1